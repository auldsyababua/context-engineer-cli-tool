# ================================================
# Context Engineer CLI Tool - Environment Variables
# ================================================
# Copy this file to .env and fill in your values
# 
# IMPORTANT: Never commit .env to version control!
# ================================================

# -------------------------------
# INFRASTRUCTURE CONFIGURATION
# -------------------------------
# How are you running MCPs?
# Options: local, docker, systemd, none
MCP_MODE=local

# Where MCPs are hosted (localhost for local mode)
MCP_HOST=localhost

# Base directory for MCP services
# Local mode: use your home directory
# Systemd mode: /opt/mcp-services
MCP_SERVICES_DIR="${HOME}/.mcp-services"

# Log directory
MCP_LOG_DIR="${HOME}/.mcp/logs"

# -------------------------------
# MCP SERVICE PORTS
# -------------------------------
# Default ports for each MCP service
# Change these if you have conflicts
MCP_GITHUB_PORT=8081
MCP_FILESYSTEM_PORT=8082
MCP_MEMORY_PORT=8083
MCP_OMNISEARCH_PORT=8084
MCP_CONTEXT7_PORT=8086
MCP_SEQUENTIAL_THINKING_PORT=8087

# -------------------------------
# RECOMMENDED MCP API KEYS
# -------------------------------
# These MCPs are highly recommended for the best experience
# All are optional, but we suggest at least GitHub and one search provider

# --- GitHub MCP (HIGHLY RECOMMENDED) ---
# Essential for repository operations
# Get your token at: https://github.com/settings/tokens/new
# Scopes needed: repo, read:org, read:user
# Token format: ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_TOKEN=

# --- Context7 MCP (RECOMMENDED) ---
# Maintains context across Claude sessions - very useful!
# Uses Upstash Redis (free tier available - 10,000 commands/day)
# Sign up at: https://console.upstash.com/
# 1. Create a Redis database
# 2. Copy the REST URL and token from the dashboard
# URL format: https://xxxxx.upstash.io
# Token format: AX_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# --- OmniSearch MCP (HIGHLY RECOMMENDED) ---
# Powerful multi-provider search - add as many providers as you want
# At minimum, we recommend Brave (free) or Kagi (paid but excellent)

# Brave Search (FREE TIER: 2,000 queries/month)
# Best free option for web search
# Get key at: https://brave.com/search/api/
# Click "Get Started" → Sign up → Get free API key
# Key format: BSA_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
BRAVE_API_KEY=

# Kagi Search (PAID: $10/month for 1,000 searches)
# Highest quality search results, no ads, privacy-focused
# Get key at: https://kagi.com/settings?p=api
# Requires paid Kagi account first
# Key format: xxx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KAGI_API_KEY=

# Perplexity (FREE TIER: Limited)
# AI-powered search summaries
# Get key at: https://www.perplexity.ai/settings/api
# Key format: pplx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PERPLEXITY_API_KEY=

# Tavily (FREE TIER: 1,000 searches/month)
# Developer-focused search API
# Get key at: https://app.tavily.com/sign-up
# Key format: tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAVILY_API_KEY=

# Jina Reader (FREE TIER: 1GB/month)
# Extracts clean content from any URL
# Get key at: https://jina.ai/reader#apiform
# Key format: jina_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JINA_API_KEY=

# Firecrawl (FREE TIER: 500 pages/month)
# Advanced web scraping and crawling
# Get key at: https://firecrawl.io/
# Sign up → Dashboard → API Keys
# Key format: fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FIRECRAWL_API_KEY=

# -------------------------------
# OPTIONAL MCP CONFIGURATIONS
# -------------------------------
# Additional MCPs you might want to use

# OpenAI (for additional AI capabilities)
# Get key at: https://platform.openai.com/api-keys
# Key format: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=

# Anthropic (if using Claude API directly)
# Get key at: https://console.anthropic.com/settings/keys
# Key format: sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=

# -------------------------------
# PROJECT-SPECIFIC SETTINGS
# -------------------------------
# Customize these for your workflow

# Your preferred code editor command
# Examples: code, cursor, subl, vim, nano
EDITOR=code

# Git configuration
GIT_DEFAULT_BRANCH=main
GIT_AUTO_COMMIT=true

# Project defaults
DEFAULT_PROJECT_TYPE=full
DEFAULT_LICENSE=MIT

# -------------------------------
# ADVANCED SETTINGS
# -------------------------------
# Only change these if you know what you're doing

# Remote MCP server settings (for systemd mode)
REMOTE_USER=
REMOTE_HOST=
REMOTE_PORT=22

# MCP service management
MCP_RESTART_DELAY=5
MCP_MAX_RETRIES=3
MCP_HEALTH_CHECK_TIMEOUT=30

# -------------------------------
# DEVELOPMENT SETTINGS
# -------------------------------
# Settings for context-engineer development

# Enable debug logging
DEBUG=false

# Show MCP communication logs
MCP_DEBUG=false

# Performance monitoring
ENABLE_METRICS=false

# ================================================
# QUICK START GUIDE
# ================================================
# 1. Copy this file: cp .env.example .env
# 2. At minimum, add:
#    - GITHUB_TOKEN (for repository operations)
#    - BRAVE_API_KEY (free web search)
# 3. Optionally add:
#    - UPSTASH_REDIS_* (for context persistence)
#    - Other search providers for better results
# 4. Run: ./setup.sh to verify your configuration
# ================================================