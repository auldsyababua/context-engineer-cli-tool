# Context Engineer Configuration
# Copy this to .env and customize for your setup

# MCP Server Configuration
# Set these to match your infrastructure
WORKHORSE_IP=localhost                    # Your MCP server IP or hostname
WORKHORSE_USER=                          # Your username on the MCP server
MCP_MASTER_DIR=                          # Path to MCP master directory on server

# Local Configuration
CONTEXT_PROJECTS_DIR=${HOME}/Desktop/projects  # Where to create projects
CONTEXT_EDITOR=code                      # Default editor command

# Optional: MCP Catalog Location
# If you have a custom MCP catalog, specify its path
# MCP_CATALOG_DIR=${HOME}/.config/context-engineer/mcp-catalog

# Optional: GitHub Configuration
# Used for automatic repository creation
# GITHUB_USERNAME=
# GITHUB_DEFAULT_ORG=

# Optional: Claude Desktop Configuration
# Path to Claude Desktop config (for MCP management)
# CLAUDE_CONFIG_DIR=${HOME}/.config/claude-desktop