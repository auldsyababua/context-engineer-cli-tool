{
  "name": "omnisearch",
  "description": "Advanced web search and content extraction with multiple search engines",
  "use_cases": [
    "Researching implementation approaches",
    "Finding solutions to technical problems",
    "Extracting content from documentation sites",
    "Discovering best practices and patterns",
    "Analyzing competitor implementations"
  ],
  "recommended_phases": [
    "research",
    "planning",
    "debugging",
    "optimization"
  ],
  "benefits": [
    "Multiple search engines (Tavily, Brave, Kagi, Perplexity)",
    "Content extraction from URLs",
    "AI-enhanced search results",
    "Domain filtering capabilities"
  ],
  "env_vars": {
    "TAVILY_API_KEY": "Get from https://app.tavily.com/",
    "BRAVE_API_KEY": "Get from https://brave.com/search/api/",
    "KAGI_API_KEY": "Get from https://kagi.com/settings/api",
    "PERPLEXITY_API_KEY": "Get from https://www.perplexity.ai/settings/api",
    "FIRECRAWL_API_KEY": "Get from https://firecrawl.dev/",
    "JINA_API_KEY": "Get from https://jina.ai/"
  },
  "mcp_config": {
    "command": "npx",
    "args": ["-y", "@neomantra/mcp-omnisearch"],
    "env": {
      "TAVILY_API_KEY": "{{TAVILY_API_KEY}}",
      "BRAVE_API_KEY": "{{BRAVE_API_KEY}}",
      "OMNISEARCH_DEBUG": "false"
    }
  },
  "setup_instructions": "At minimum, configure one search API key (Tavily recommended for free tier). More APIs provide better coverage.",
  "documentation": "https://github.com/neomantra/mcp-omnisearch",
  "example_prompts": [
    "Search for the latest Python async best practices",
    "Find examples of successful Telegram bot architectures",
    "Research n8n workflow automation patterns",
    "Extract content from the React documentation"
  ]
}