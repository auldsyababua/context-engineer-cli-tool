#!/bin/bash

# MCP Phase Activator
# Generates phase-specific MCP configurations

set -e

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# Functions
print_header() {
    echo -e "\n${BLUE}══════════════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}$1${NC}"
    echo -e "${BLUE}══════════════════════════════════════════════════════════════${NC}\n"
}

print_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

print_error() {
    echo -e "${RED}❌ $1${NC}"
}

# Check if jq is installed
if ! command -v jq &> /dev/null; then
    print_error "jq is required but not installed"
    exit 1
fi

# Check if we're in a project with MCP
if [[ ! -d ".mcp" ]]; then
    print_error "No .mcp directory found. Are you in a Context Engineering project?"
    exit 1
fi

# Show usage
show_usage() {
    cat << EOF
MCP Phase Activator

Usage: mcp-phase [command] [phase]

Commands:
  activate <phase>    Activate MCPs for a specific phase
  list               List available phase configurations
  show <phase>       Show MCPs for a phase
  current            Show currently active MCPs
  disable            Disable all MCPs

Phases:
  research          Research & analysis phase
  development       Active development phase
  testing           Testing & debugging phase
  deployment        Deployment & release phase

Examples:
  mcp-phase activate research
  mcp-phase show development
  mcp-phase current
EOF
}

# Get MCP config path
get_mcp_config() {
    # First check project-specific configs
    if [[ -d ".mcp/phase-configs" ]]; then
        echo ".mcp/phase-configs"
    # Then check global configs
    elif [[ -d "$HOME/.config/context-engineer/mcp/phase-configs" ]]; then
        echo "$HOME/.config/context-engineer/mcp/phase-configs"
    else
        print_error "No phase configurations found"
        exit 1
    fi
}

# Get master MCP config
get_master_config() {
    if [[ -f ".mcp/mcp-config.json" ]]; then
        echo ".mcp/mcp-config.json"
    elif [[ -f "$HOME/.config/context-engineer/mcp/mcp-config.json" ]]; then
        echo "$HOME/.config/context-engineer/mcp/mcp-config.json"
    else
        print_error "No master MCP configuration found"
        exit 1
    fi
}

# List available phases
list_phases() {
    local config_dir=$(get_mcp_config)
    
    print_header "Available Phase Configurations"
    
    for config in "$config_dir"/*.json; do
        if [[ -f "$config" ]]; then
            local phase=$(basename "$config" .json | sed 's/-phase$//')
            local name=$(jq -r '.name' "$config")
            local desc=$(jq -r '.description' "$config")
            
            echo -e "${CYAN}$phase${NC}"
            echo "  Name: $name"
            echo "  Description: $desc"
            echo ""
        fi
    done
}

# Show MCPs for a phase
show_phase() {
    local phase=$1
    local config_dir=$(get_mcp_config)
    local phase_file="$config_dir/${phase}-phase.json"
    
    if [[ ! -f "$phase_file" ]]; then
        print_error "Phase configuration not found: $phase"
        exit 1
    fi
    
    print_header "MCPs for $phase phase"
    
    local name=$(jq -r '.name' "$phase_file")
    echo -e "${BLUE}$name${NC}\n"
    
    # Show MCPs and rationale
    jq -r '.mcps[]' "$phase_file" | while read -r mcp; do
        local rationale=$(jq -r ".rationale.\"$mcp\"" "$phase_file")
        echo -e "${GREEN}✓ $mcp${NC}"
        echo "  $rationale"
        echo ""
    done
}

# Activate phase MCPs
activate_phase() {
    local phase=$1
    local config_dir=$(get_mcp_config)
    local phase_file="$config_dir/${phase}-phase.json"
    local master_config=$(get_master_config)
    
    if [[ ! -f "$phase_file" ]]; then
        print_error "Phase configuration not found: $phase"
        exit 1
    fi
    
    print_header "Activating $phase phase MCPs"
    
    # Create new mcp.json
    echo '{' > .mcp/mcp.json.tmp
    echo '  "mcpServers": {' >> .mcp/mcp.json.tmp
    
    # Get MCPs for this phase
    local mcps=$(jq -r '.mcps[]' "$phase_file")
    local first=true
    
    for mcp in $mcps; do
        # Get config from master
        local config=$(jq -c ".available_mcps.\"$mcp\"" "$master_config")
        
        if [[ "$config" != "null" ]]; then
            if [[ "$first" != "true" ]]; then
                echo ',' >> .mcp/mcp.json.tmp
            fi
            echo -n "    \"$mcp\": $config" >> .mcp/mcp.json.tmp
            first=false
            print_success "Added $mcp"
        else
            print_error "MCP $mcp not found in master config"
        fi
    done
    
    echo '' >> .mcp/mcp.json.tmp
    echo '  }' >> .mcp/mcp.json.tmp
    echo '}' >> .mcp/mcp.json.tmp
    
    # Pretty format and move
    jq '.' .mcp/mcp.json.tmp > .mcp/mcp.json
    rm .mcp/mcp.json.tmp
    
    # Save current phase
    echo "$phase" > .mcp/current-phase
    
    print_success "Phase MCPs activated!"
    echo ""
    echo "Next steps:"
    echo "1. Ensure required API keys are in .env"
    echo "2. Restart Claude Code to load new MCPs"
}

# Show current MCPs
show_current() {
    print_header "Currently Active MCPs"
    
    if [[ -f ".mcp/current-phase" ]]; then
        local phase=$(cat .mcp/current-phase)
        echo -e "Active phase: ${YELLOW}$phase${NC}\n"
    fi
    
    if [[ -f ".mcp/mcp.json" ]]; then
        local mcps=$(jq -r '.mcpServers | keys[]' .mcp/mcp.json 2>/dev/null)
        if [[ -n "$mcps" ]]; then
            echo "Active MCPs:"
            for mcp in $mcps; do
                echo -e "  ${GREEN}✓ $mcp${NC}"
            done
        else
            echo "No MCPs currently active"
        fi
    else
        echo "No mcp.json file found"
    fi
}

# Disable all MCPs
disable_mcps() {
    print_header "Disabling All MCPs"
    
    cat > .mcp/mcp.json << EOF
{
  "mcpServers": {}
}
EOF
    
    rm -f .mcp/current-phase
    
    print_success "All MCPs disabled"
}

# Main command router
case "${1:-help}" in
    activate)
        if [[ -z "$2" ]]; then
            print_error "Usage: mcp-phase activate <phase>"
            exit 1
        fi
        activate_phase "$2"
        ;;
    list)
        list_phases
        ;;
    show)
        if [[ -z "$2" ]]; then
            print_error "Usage: mcp-phase show <phase>"
            exit 1
        fi
        show_phase "$2"
        ;;
    current)
        show_current
        ;;
    disable)
        disable_mcps
        ;;
    help|--help|-h|"")
        show_usage
        ;;
    *)
        print_error "Unknown command: $1"
        show_usage
        exit 1
        ;;
esac