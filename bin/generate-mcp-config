#!/bin/bash
# Generate MCP configuration based on .env.mcp settings

set -e

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# Load environment
if [[ -f .env ]]; then
    source .env
fi

if [[ -f .env.mcp ]]; then
    source .env.mcp
else
    echo -e "${RED}Error: .env.mcp not found!${NC}"
    echo "Please copy .env.mcp.example to .env.mcp and add your API keys."
    exit 1
fi

# Output directory
OUTPUT_DIR="${HOME}/.config/claude-code"
mkdir -p "$OUTPUT_DIR"

# Generate config
cat > "$OUTPUT_DIR/mcp-config.json" << EOF
{
  "mcpServers": {
EOF

FIRST=true

# Add GitHub if token exists
if [[ -n "$GITHUB_TOKEN" ]]; then
    if [[ "$FIRST" != true ]]; then echo "," >> "$OUTPUT_DIR/mcp-config.json"; fi
    cat >> "$OUTPUT_DIR/mcp-config.json" << EOF
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      }
    }
EOF
    FIRST=false
fi

# Add Filesystem
if [[ "$FIRST" != true ]]; then echo "," >> "$OUTPUT_DIR/mcp-config.json"; fi
cat >> "$OUTPUT_DIR/mcp-config.json" << EOF
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "$HOME"]
    }
EOF
FIRST=false

# Add Memory
if [[ "$FIRST" != true ]]; then echo "," >> "$OUTPUT_DIR/mcp-config.json"; fi
cat >> "$OUTPUT_DIR/mcp-config.json" << EOF
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    }
EOF
FIRST=false

# Add Context7 if configured
if [[ -n "$UPSTASH_REDIS_URL" ]] && [[ -n "$UPSTASH_REDIS_TOKEN" ]]; then
    if [[ "$FIRST" != true ]]; then echo "," >> "$OUTPUT_DIR/mcp-config.json"; fi
    cat >> "$OUTPUT_DIR/mcp-config.json" << EOF
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {
        "UPSTASH_REDIS_URL": "$UPSTASH_REDIS_URL",
        "UPSTASH_REDIS_TOKEN": "$UPSTASH_REDIS_TOKEN"
      }
    }
EOF
    FIRST=false
fi

# Add OmniSearch if any search provider is configured
if [[ -n "$BRAVE_API_KEY" ]] || [[ -n "$KAGI_API_KEY" ]] || \
   [[ -n "$PERPLEXITY_API_KEY" ]] || [[ -n "$TAVILY_API_KEY" ]]; then
    if [[ "$FIRST" != true ]]; then echo "," >> "$OUTPUT_DIR/mcp-config.json"; fi
    cat >> "$OUTPUT_DIR/mcp-config.json" << EOF
    "omnisearch": {
      "command": "npx",
      "args": ["-y", "mcp-omnisearch"],
      "env": {
EOF
    
    ENV_FIRST=true
    if [[ -n "$BRAVE_API_KEY" ]]; then
        if [[ "$ENV_FIRST" != true ]]; then echo "," >> "$OUTPUT_DIR/mcp-config.json"; fi
        echo "        \"BRAVE_API_KEY\": \"$BRAVE_API_KEY\"" >> "$OUTPUT_DIR/mcp-config.json"
        ENV_FIRST=false
    fi
    
    if [[ -n "$KAGI_API_KEY" ]]; then
        if [[ "$ENV_FIRST" != true ]]; then echo "," >> "$OUTPUT_DIR/mcp-config.json"; fi
        echo "        \"KAGI_API_KEY\": \"$KAGI_API_KEY\"" >> "$OUTPUT_DIR/mcp-config.json"
        ENV_FIRST=false
    fi
    
    if [[ -n "$PERPLEXITY_API_KEY" ]]; then
        if [[ "$ENV_FIRST" != true ]]; then echo "," >> "$OUTPUT_DIR/mcp-config.json"; fi
        echo "        \"PERPLEXITY_API_KEY\": \"$PERPLEXITY_API_KEY\"" >> "$OUTPUT_DIR/mcp-config.json"
        ENV_FIRST=false
    fi
    
    if [[ -n "$TAVILY_API_KEY" ]]; then
        if [[ "$ENV_FIRST" != true ]]; then echo "," >> "$OUTPUT_DIR/mcp-config.json"; fi
        echo "        \"TAVILY_API_KEY\": \"$TAVILY_API_KEY\"" >> "$OUTPUT_DIR/mcp-config.json"
        ENV_FIRST=false
    fi
    
    if [[ -n "$JINA_API_KEY" ]]; then
        if [[ "$ENV_FIRST" != true ]]; then echo "," >> "$OUTPUT_DIR/mcp-config.json"; fi
        echo "        \"JINA_API_KEY\": \"$JINA_API_KEY\"" >> "$OUTPUT_DIR/mcp-config.json"
        ENV_FIRST=false
    fi
    
    if [[ -n "$FIRECRAWL_API_KEY" ]]; then
        if [[ "$ENV_FIRST" != true ]]; then echo "," >> "$OUTPUT_DIR/mcp-config.json"; fi
        echo "        \"FIRECRAWL_API_KEY\": \"$FIRECRAWL_API_KEY\"" >> "$OUTPUT_DIR/mcp-config.json"
        ENV_FIRST=false
    fi
    
    cat >> "$OUTPUT_DIR/mcp-config.json" << EOF

      }
    }
EOF
    FIRST=false
fi

# Add Sequential Thinking
if [[ "$FIRST" != true ]]; then echo "," >> "$OUTPUT_DIR/mcp-config.json"; fi
cat >> "$OUTPUT_DIR/mcp-config.json" << EOF
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
EOF

# Close the config
cat >> "$OUTPUT_DIR/mcp-config.json" << EOF

  }
}
EOF

echo -e "${GREEN}✅ Generated MCP configuration${NC}"
echo "Location: $OUTPUT_DIR/mcp-config.json"
echo ""
echo "Enabled MCPs:"

[[ -n "$GITHUB_TOKEN" ]] && echo "  - GitHub"
echo "  - Filesystem"
echo "  - Memory"
[[ -n "$UPSTASH_REDIS_URL" ]] && echo "  - Context7"
[[ -n "$BRAVE_API_KEY" ]] || [[ -n "$KAGI_API_KEY" ]] && echo "  - OmniSearch"
echo "  - Sequential Thinking"

echo ""
echo -e "${YELLOW}Note:${NC} This configuration is for local MCP usage with Claude Code."
echo "Context Engineer will automatically detect and use available MCPs."