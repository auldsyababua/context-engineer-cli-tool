#!/bin/bash

# Context Engineer Update Script
# Updates an existing Context Engineer project with latest features

set -e

# Colors for output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# Get the source directory (where this script lives)
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
CE_ROOT="$(dirname "$SCRIPT_DIR")"

print_header() {
    echo -e "\n${BLUE}══════════════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}$1${NC}"
    echo -e "${BLUE}══════════════════════════════════════════════════════════════${NC}\n"
}

print_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

print_error() {
    echo -e "${RED}❌ $1${NC}"
}

# Main update function
update_project() {
    local target_dir="${1:-.}"
    
    # Convert to absolute path
    target_dir=$(cd "$target_dir" && pwd)
    
    print_header "Context Engineer Update Tool"
    
    # Check if it's a Context Engineer project
    if [[ ! -f "$target_dir/CLAUDE.md" ]] || [[ ! -d "$target_dir/.claude" ]]; then
        print_error "This doesn't appear to be a Context Engineer project!"
        echo "Looking for CLAUDE.md and .claude/ directory"
        exit 1
    fi
    
    echo "Updating project at: $target_dir"
    echo "From source: $CE_ROOT"
    echo ""
    
    # Create backup
    print_header "Creating Backup..."
    backup_dir="$target_dir/.claude-backup-$(date +%Y%m%d-%H%M%S)"
    mkdir -p "$backup_dir"
    
    # Backup key files
    if [[ -f "$target_dir/CLAUDE.md" ]]; then
        cp "$target_dir/CLAUDE.md" "$backup_dir/"
        print_success "Backed up CLAUDE.md"
    fi
    
    if [[ -f "$target_dir/PLANNING.md" ]]; then
        cp "$target_dir/PLANNING.md" "$backup_dir/"
        print_success "Backed up PLANNING.md"
    fi
    
    if [[ -d "$target_dir/.claude" ]]; then
        cp -r "$target_dir/.claude" "$backup_dir/"
        print_success "Backed up .claude directory"
    fi
    
    # Update .claude directory structure
    print_header "Updating .claude Directory..."
    
    # Ensure directories exist
    mkdir -p "$target_dir/.claude/commands"
    mkdir -p "$target_dir/.mcp"
    
    # Copy command files
    if [[ -d "$CE_ROOT/.claude/commands" ]]; then
        cp -r "$CE_ROOT/.claude/commands/"* "$target_dir/.claude/commands/" 2>/dev/null || true
        print_success "Updated command files"
    fi
    
    # Copy settings.json if it doesn't exist
    if [[ ! -f "$target_dir/.claude/settings.json" ]] && [[ -f "$CE_ROOT/.claude/settings.json" ]]; then
        cp "$CE_ROOT/.claude/settings.json" "$target_dir/.claude/"
        print_success "Added settings.json"
    fi
    
    # Update templates
    print_header "Updating Templates..."
    
    # Copy analysis templates if they don't exist
    if [[ ! -f "$target_dir/templates/REFACTOR_ANALYSIS.md" ]] && [[ -f "$CE_ROOT/templates/REFACTOR_ANALYSIS.md" ]]; then
        mkdir -p "$target_dir/templates"
        cp "$CE_ROOT/templates/REFACTOR_ANALYSIS.md" "$target_dir/templates/"
        cp "$CE_ROOT/templates/RETRY_ANALYSIS.md" "$target_dir/templates/"
        print_success "Added analysis templates"
    fi
    
    # Update .gitignore
    print_header "Updating .gitignore..."
    
    # Add new gitignore entries if not present
    if [[ -f "$target_dir/.gitignore" ]]; then
        # Check for MCP entries
        if ! grep -q "^.mcp/mcp.json" "$target_dir/.gitignore"; then
            echo -e "\n# MCP with injected keys" >> "$target_dir/.gitignore"
            echo ".mcp/mcp.json" >> "$target_dir/.gitignore"
            echo ".mcp/mcp.json.bak" >> "$target_dir/.gitignore"
            echo "!.mcp/mcp.json.template" >> "$target_dir/.gitignore"
            print_success "Added MCP entries to .gitignore"
        fi
        
        # Check for session files
        if ! grep -q "^.context-session" "$target_dir/.gitignore"; then
            echo -e "\n# Session files" >> "$target_dir/.gitignore"
            echo ".context-session" >> "$target_dir/.gitignore"
            echo ".current-phase" >> "$target_dir/.gitignore"
            print_success "Added session entries to .gitignore"
        fi
    fi
    
    # Check for MCP setup
    print_header "Checking MCP Configuration..."
    
    if [[ ! -f "$target_dir/.mcp/mcp.json" ]] && [[ ! -f "$target_dir/.mcp/mcp.json.template" ]]; then
        print_warning "No MCP configuration found"
        echo "To set up MCPs for this project:"
        echo "1. Run: mcp-phase activate research"
        echo "2. Run: mcp-inject"
    else
        print_success "MCP configuration exists"
    fi
    
    # Update PLANNING.md if template exists
    if [[ -f "$CE_ROOT/templates/PLANNING.md" ]] && [[ ! -f "$target_dir/PLANNING.md" ]]; then
        cp "$CE_ROOT/templates/PLANNING.md" "$target_dir/"
        print_success "Added PLANNING.md template"
    fi
    
    # Summary
    print_header "Update Complete!"
    
    echo "Updated components:"
    echo "- .claude/commands/ (latest Claude commands)"
    echo "- .gitignore (MCP and session entries)"
    echo "- Template files (if missing)"
    echo ""
    echo "Backup saved at: $backup_dir"
    echo ""
    
    # Check if we're in a different phase structure
    if [[ -d "$target_dir/phases" ]]; then
        echo -e "${GREEN}Project uses phase structure${NC}"
        echo "You can use context-auto to continue development"
    fi
    
    # Suggest next steps
    echo -e "\n${BLUE}Next steps:${NC}"
    echo "1. Review any changes with: git diff"
    echo "2. Set up MCPs if needed: mcp-phase activate <phase>"
    echo "3. Continue development with your current workflow"
}

# Show help
show_help() {
    cat << EOF
Context Engineer Update Tool

Updates an existing Context Engineer project with the latest features,
commands, and improvements.

Usage: context-update [path]

Arguments:
  path      Path to the project to update (default: current directory)

Examples:
  context-update                    # Update current directory
  context-update ~/projects/myapp   # Update specific project

The updater will:
- Back up existing configuration
- Update .claude/commands/ with latest commands
- Add new .gitignore entries for MCPs and sessions
- Add missing template files
- Preserve your existing CLAUDE.md and project files

EOF
}

# Parse arguments
case "${1:-}" in
    --help|-h)
        show_help
        exit 0
        ;;
    *)
        update_project "$@"
        ;;
esac