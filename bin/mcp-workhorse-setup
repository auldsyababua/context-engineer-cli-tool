#!/bin/bash

# Initial setup script for MCP master configuration on workhorse
# This creates the initial structure on the workhorse server

# Load configuration from multiple sources
# 1. Default values
WORKHORSE_IP="${WORKHORSE_IP:-localhost}"
WORKHORSE_USER="${WORKHORSE_USER:-$(whoami)}"
MCP_MASTER_DIR="${MCP_MASTER_DIR:-$HOME/mcp-master}"

# 2. Load from config file if it exists
if [[ -f "$HOME/.config/context-engineer/config.env" ]]; then
    source "$HOME/.config/context-engineer/config.env"
fi

# 3. Load from local .env if it exists (project-specific overrides)
if [[ -f ".env" ]]; then
    source ".env"
fi

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}Setting up MCP master configuration on workhorse...${NC}"

# Check SSH connectivity
if ! ssh -q -o ConnectTimeout=5 $WORKHORSE_USER@$WORKHORSE_IP exit 2>/dev/null; then
    echo -e "${RED}❌ Cannot connect to workhorse at $WORKHORSE_IP${NC}"
    echo "Make sure:"
    echo "1. Workhorse is powered on"
    echo "2. You're on the same network"
    echo "3. SSH key authentication is set up"
    exit 1
fi

echo -e "${GREEN}✅ Connected to workhorse${NC}"

# Create directory structure
echo -e "${BLUE}Creating directory structure...${NC}"
ssh $WORKHORSE_USER@$WORKHORSE_IP "mkdir -p $MCP_MASTER_DIR/phase-configs"

# Create initial api-keys.env template
echo -e "${BLUE}Creating api-keys.env template...${NC}"
ssh $WORKHORSE_USER@$WORKHORSE_IP "cat > $MCP_MASTER_DIR/api-keys.env" << 'EOF'
# Master API Key Store
# NEVER commit or share this file
# Created: $(date +%Y-%m-%d)

# ============================================
# Search & Research APIs
# ============================================
TAVILY_API_KEY=tvly-your-actual-key-here
BRAVE_API_KEY=your-brave-api-key-here
KAGI_API_KEY=your-kagi-key-here
PERPLEXITY_API_KEY=pplx-your-key-here

# ============================================
# Development APIs
# ============================================
GITHUB_PERSONAL_ACCESS_TOKEN=ghp-your-token-here
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ============================================
# Communication APIs
# ============================================
TELEGRAM_API_ID=your-telegram-id
TELEGRAM_API_HASH=your-telegram-hash
TELEGRAM_BOT_TOKEN=your-bot-token

# ============================================
# Task Management
# ============================================
TODOIST_API_TOKEN=your-todoist-token

# ============================================
# Documentation
# ============================================
# Add your API keys above
# To get keys:
# - Tavily: https://app.tavily.com/
# - Brave: https://brave.com/search/api/
# - GitHub: https://github.com/settings/tokens
# - Todoist: https://todoist.com/app/settings/integrations
EOF

# Create master MCP config
echo -e "${BLUE}Creating mcp-config-master.json...${NC}"
ssh $WORKHORSE_USER@$WORKHORSE_IP "cat > $MCP_MASTER_DIR/mcp-config-master.json" << 'EOF'
{
  "master_version": "1.0",
  "last_updated": "$(date +%Y-%m-%d)",
  "available_mcps": {
    "omnisearch": {
      "command": "npx",
      "args": ["-y", "@neomantra/mcp-omnisearch"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}",
        "BRAVE_API_KEY": "${BRAVE_API_KEY}",
        "KAGI_API_KEY": "${KAGI_API_KEY}",
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}",
        "OMNISEARCH_DEBUG": "false"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem"],
      "env": {
        "FILESYSTEM_ROOT": "${HOME}/Desktop/projects"
      }
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@context7/mcp-server"],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    },
    "todoist": {
      "command": "npx",
      "args": ["-y", "@todoist/mcp-server"],
      "env": {
        "TODOIST_API_TOKEN": "${TODOIST_API_TOKEN}"
      }
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    }
  }
}
EOF

# Copy phase configs from local
echo -e "${BLUE}Copying phase configurations...${NC}"
if [[ -d "$HOME/.config/context-engineer/mcp/phase-configs" ]]; then
    scp -r $HOME/.config/context-engineer/mcp/phase-configs/* \
        $WORKHORSE_USER@$WORKHORSE_IP:$MCP_MASTER_DIR/phase-configs/
elif [[ -d "$(dirname "${BASH_SOURCE[0]}")/../templates/.mcp/phase-configs" ]]; then
    scp -r "$(dirname "${BASH_SOURCE[0]}")/../templates/.mcp/phase-configs"/* \
        $WORKHORSE_USER@$WORKHORSE_IP:$MCP_MASTER_DIR/phase-configs/
fi

echo -e "${GREEN}✅ Workhorse setup complete!${NC}"
echo ""
echo -e "${YELLOW}Next steps:${NC}"
echo "1. SSH to workhorse: ssh $WORKHORSE_USER@$WORKHORSE_IP"
echo "2. Edit API keys: nano $MCP_MASTER_DIR/api-keys.env"
echo "3. Add your actual API keys"
echo "4. Run 'mcp-sync' to pull configurations"
echo ""
echo -e "${BLUE}Useful commands:${NC}"
echo "• mcp-sync     - Pull latest configs from workhorse"
echo "• mcp-inject   - Inject API keys into current project"
echo "• mcp-edit     - Edit master config via SSH"
echo "• mcp-keys     - Edit API keys via SSH"