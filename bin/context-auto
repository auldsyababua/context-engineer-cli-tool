#!/bin/bash

# Context Engineer Auto-Pilot Mode
# Continuous development with automatic progression and git safety

set -e

# Colors for better UX
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Session state file
SESSION_STATE_FILE=".context-session"
ROADMAP_FILE="ROADMAP.md"
CURRENT_PHASE_FILE=".current-phase"

# Utility functions
print_header() {
    echo -e "\n${BLUE}══════════════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}$1${NC}"
    echo -e "${BLUE}══════════════════════════════════════════════════════════════${NC}\n"
}

print_phase() {
    echo -e "\n${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${YELLOW}🚀 PHASE: $1${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"
}

print_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

print_error() {
    echo -e "${RED}❌ $1${NC}"
}

# Auto-commit function
auto_commit() {
    local phase=$1
    local step=$2
    
    if [[ -n $(git status --porcelain) ]]; then
        git add -A
        git commit -m "Auto-commit: Phase $phase - $step" --quiet
        print_success "Changes committed: Phase $phase - $step"
    fi
}

# Save session state
save_session_state() {
    local phase=$1
    local step=$2
    local status=$3
    
    cat > "$SESSION_STATE_FILE" << EOF
CURRENT_PHASE="$phase"
CURRENT_STEP="$step"
STATUS="$status"
TIMESTAMP="$(date +%Y-%m-%d_%H:%M:%S)"
PROJECT_PATH="$(pwd)"
PROJECT_TYPE="${project_option:-1}"
EOF
}

# Load session state
load_session_state() {
    if [[ -f "$SESSION_STATE_FILE" ]]; then
        source "$SESSION_STATE_FILE"
        return 0
    fi
    return 1
}

# Format project name to valid directory name
format_project_name() {
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//'
}

# Create new project
create_new_project() {
    echo -e "\n${BLUE}What would you like to do?${NC}\n"
    echo "1) Create a new project from scratch"
    echo "2) Refactor an existing project"
    echo "3) Retry a previous attempt"
    echo ""
    read -p "Choose option [1]: " project_option
    project_option=${project_option:-1}
    
    # Get project name
    read -p "What's your project name? " project_name
    
    if [[ -z "$project_name" ]]; then
        print_error "Project name cannot be empty!"
        exit 1
    fi
    
    # Format the name
    formatted_name=$(format_project_name "$project_name")
    if [[ "$project_name" != "$formatted_name" ]]; then
        echo -e "Directory name: ${YELLOW}$formatted_name${NC}"
    fi
    
    # Determine project location
    DEFAULT_PROJECTS_DIR="${CONTEXT_ENGINEER_PROJECTS_DIR:-$HOME/projects}"
    
    if [[ ! -d "$DEFAULT_PROJECTS_DIR" ]]; then
        print_warning "Default projects directory not found: $DEFAULT_PROJECTS_DIR"
        read -p "Create it? (y/n) [y]: " create_default
        create_default=${create_default:-y}
        
        if [[ "$create_default" == "y" ]]; then
            mkdir -p "$DEFAULT_PROJECTS_DIR"
            print_success "Created $DEFAULT_PROJECTS_DIR"
            PROJECT_PATH="$DEFAULT_PROJECTS_DIR/$formatted_name"
        else
            read -p "Enter custom project path: " custom_path
            PROJECT_PATH="$custom_path/$formatted_name"
            mkdir -p "$(dirname "$PROJECT_PATH")"
        fi
    else
        PROJECT_PATH="$DEFAULT_PROJECTS_DIR/$formatted_name"
    fi
    
    # Check if project already exists
    if [[ -d "$PROJECT_PATH" ]]; then
        print_error "Project already exists at: $PROJECT_PATH"
        read -p "Use existing project? (y/n) [n]: " use_existing
        use_existing=${use_existing:-n}
        if [[ "$use_existing" != "y" ]]; then
            exit 1
        fi
    else
        # Create project directory and basic structure
        mkdir -p "$PROJECT_PATH"/{.claude/commands,phases,future-features,docs,templates}
        
        # Copy minimal templates from the CLI tool
        SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
        TEMPLATES_DIR="$(dirname "$SCRIPT_DIR")/templates"
        
        if [[ -d "$TEMPLATES_DIR" ]]; then
            cp "$TEMPLATES_DIR/CLAUDE.md" "$PROJECT_PATH/" 2>/dev/null || true
            # Don't copy ROADMAP.md - it should be generated by Claude
            cp -r "$TEMPLATES_DIR/.claude" "$PROJECT_PATH/" 2>/dev/null || true
            # MCP configuration handled separately
            cp -r "$TEMPLATES_DIR/examples" "$PROJECT_PATH/" 2>/dev/null || true
            
            # Copy analysis templates for refactor/retry projects
            if [[ "$project_option" == "2" ]]; then
                cp "$TEMPLATES_DIR/REFACTOR_ANALYSIS.md" "$PROJECT_PATH/templates/" 2>/dev/null || true
            elif [[ "$project_option" == "3" ]]; then
                cp "$TEMPLATES_DIR/RETRY_ANALYSIS.md" "$PROJECT_PATH/templates/" 2>/dev/null || true
            fi
            
            # Customize CLAUDE.md with project name
            if [[ -f "$PROJECT_PATH/CLAUDE.md" ]]; then
                sed -i.bak "s/PROJECT_NAME/$project_name/g" "$PROJECT_PATH/CLAUDE.md"
                rm "$PROJECT_PATH/CLAUDE.md.bak"
            fi
        fi
        
        # Create comprehensive gitignore
        cat > "$PROJECT_PATH/.gitignore" << 'EOF'
# Environment Variables - NEVER COMMIT THESE
.env
.env.*
!.env.example
!.env.template
*.env
config/secrets.*
secrets/

# Claude settings - local overrides
.claude/settings.local.json
!.claude/settings.local.json.example

# Virtual Environments
venv/
env/
.venv/
ENV/

# API Keys and Credentials  
*.pem
*.key
*.cert
credentials.json
*-account*.json

# Session files
.context-session
.current-phase

# Project specific
data/
*.db
*.sqlite
EOF

        # Create .env.example with phase structure
        cat > "$PROJECT_PATH/.env.example" << 'EOF'
# Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# PHASE 1: Basic Setup
# ============================================
# No environment variables required for Phase 1

# ============================================
# PHASE 2+: To be defined during roadmap generation
# ============================================
# Additional phases and their requirements will be added
# when you generate the project roadmap
EOF
        
        print_success "Created project at: $PROJECT_PATH"
    fi
    
    # Handle different project options
    case $project_option in
        2) # Refactor
            echo ""
            read -p "Path to existing project to refactor: " existing_path
            
            if [[ ! -d "$existing_path" ]]; then
                print_error "Project path not found: $existing_path"
                exit 1
            fi
            
            # Gather refactor information
            echo -e "\n${BLUE}Let's understand what needs refactoring:${NC}"
            
            echo "What are the main problems with the current codebase?"
            read -r -p "> " refactor_problems
            
            echo -e "\nWhat would you like to improve or modernize?"
            read -r -p "> " refactor_goals
            
            echo -e "\nAny specific technologies/patterns to adopt?"
            read -r -p "> " refactor_tech
            
            # Save refactor context
            cat > "$PROJECT_PATH/REFACTOR_CONTEXT.md" << EOF
# Refactoring Context

## Original Project Path
$existing_path

## Current Problems
$refactor_problems

## Improvement Goals
$refactor_goals

## Technologies/Patterns to Adopt
$refactor_tech

## Analysis Requirements
- Analyze the existing codebase structure
- Identify technical debt and anti-patterns
- Assess current test coverage
- Review dependencies for updates/replacements
- Understand the domain logic that must be preserved

## Refactoring Principles
- Preserve all existing functionality
- Improve code organization incrementally
- Add tests before refactoring
- Document architectural decisions
- Maintain backward compatibility where needed
EOF
            
            print_success "Refactor context saved"
            ;;
            
        3) # Retry
            echo ""
            read -p "Path to previous attempt: " previous_path
            
            if [[ ! -d "$previous_path" ]]; then
                print_error "Previous project path not found: $previous_path"
                exit 1
            fi
            
            # Gather retry information
            echo -e "\n${BLUE}Let's learn from the previous attempt:${NC}"
            
            echo "What went wrong in the previous attempt?"
            read -r -p "> " retry_problems
            
            echo -e "\nWhat worked well and should be kept?"
            read -r -p "> " retry_successes
            
            echo -e "\nWhat would you do differently this time?"
            read -r -p "> " retry_changes
            
            # Save retry context
            cat > "$PROJECT_PATH/RETRY_CONTEXT.md" << EOF
# Retry Context

## Previous Attempt Path
$previous_path

## What Went Wrong
$retry_problems

## What Worked Well
$retry_successes

## Planned Changes
$retry_changes

## Analysis Requirements
- Review the previous implementation thoroughly
- Identify architectural flaws that caused issues
- Extract reusable components and patterns
- Understand why certain approaches failed
- Document lessons learned

## Retry Principles
- Build on successful patterns from previous attempt
- Avoid previously identified pitfalls
- Simplify overly complex solutions
- Focus on core functionality first
- Plan for iterative improvements
EOF
            
            print_success "Retry context saved"
            ;;
    esac
    
    # Change to project directory
    cd "$PROJECT_PATH"
    
    # Export PROJECT_PATH for the rest of the script
    export PROJECT_PATH
}

# Generate roadmap prompt
generate_roadmap_prompt() {
    local project_name=$1
    local feature_description=$2
    local project_type=$3
    
    cat << EOF
# Context Engineer - Roadmap Generation

Please create a comprehensive development roadmap for this project.

## Project: $project_name

## Main Feature/Goal:
$feature_description

## Your Task:
Analyze this goal and create a logical phase breakdown. Consider:
- What's the simplest working version? (Phase 1)
- What features naturally build on each other?
- What are the technical dependencies?
- Where are the natural testing/validation points?
- What would constitute meaningful milestones?

EOF

    # Add context-specific information
    if [[ -f "REFACTOR_CONTEXT.md" ]]; then
        echo "## Refactoring Context"
        cat REFACTOR_CONTEXT.md
        echo ""
        echo "## IMPORTANT: Analysis Phase Required"
        echo "Before creating the roadmap, you MUST:"
        echo "1. Use Glob and Grep extensively to understand the codebase structure"
        echo "2. Analyze the existing architecture and identify patterns"
        echo "3. Assess the current state (tests, docs, dependencies)"
        echo "4. Identify technical debt and improvement opportunities"
        echo ""
        echo "## Recommended MCP Profile for Analysis:"
        echo "- **sequential-thinking**: To systematically analyze the codebase"
        echo "- **memory**: To track findings and decisions"
        echo "- **omnisearch**: To research modern alternatives to outdated patterns"
        echo ""
        echo "After analysis, create a roadmap that:"
        echo "- Preserves all working functionality"
        echo "- Modernizes incrementally (no big-bang rewrites)"
        echo "- Adds tests before refactoring"
        echo "- Documents architectural improvements"
        echo ""
        echo "## Create ANALYSIS.md"
        echo "Document your findings using the structure in:"
        echo "templates/REFACTOR_ANALYSIS.md"
        echo ""
    elif [[ -f "RETRY_CONTEXT.md" ]]; then
        echo "## Retry Context" 
        cat RETRY_CONTEXT.md
        echo ""
        echo "## IMPORTANT: Analysis Phase Required"
        echo "Before creating the roadmap, you MUST:"
        echo "1. Use Glob and Grep to thoroughly review the previous attempt"
        echo "2. Identify what caused the stated problems"
        echo "3. Extract successful patterns to reuse"
        echo "4. Understand the domain logic deeply"
        echo ""
        echo "## Recommended MCP Profile for Analysis:"
        echo "- **sequential-thinking**: To analyze what went wrong systematically"
        echo "- **memory**: To track lessons learned"
        echo "- **context7**: To check for updated library docs if relevant"
        echo ""
        echo "After analysis, create a roadmap that:"
        echo "- Learns from ALL previous mistakes"
        echo "- Reuses successful components"
        echo "- Simplifies overly complex solutions"
        echo "- Has clear success criteria for each phase"
        echo ""
        echo "## Create ANALYSIS.md"
        echo "Document your findings using the structure in:"
        echo "templates/RETRY_ANALYSIS.md"
        echo ""
    fi
    
    cat << EOF
## Requirements:
1. Analyze the project scope and determine the optimal number of phases
2. Each phase should:
   - Be a logical, self-contained milestone
   - Build upon previous phases
   - Bias toward more, simple modules over fewer, complex ones
   - Have clear, testable success criteria
3. Typically projects need 3-8 phases, but use as many as needed
4. Create the following structure:

\`\`\`
ANALYSIS.md                   # (For refactor/retry only) Your analysis findings
ROADMAP.md                    # Overview of all phases
.env.example                  # Complete environment template with phase info
phases/
├── phase-1/
│   ├── INITIAL.md           # Feature description for phase 1
│   └── SUCCESS_CRITERIA.md  # What marks this phase complete
├── phase-2/
│   ├── INITIAL.md
│   └── SUCCESS_CRITERIA.md
└── ...
\`\`\`

## Phase Planning Guidelines:
- **Start simple**: Phase 1 should be a working MVP or foundation
- **Incremental value**: Each phase adds usable functionality
- **Natural breakpoints**: Align with technical boundaries
- **Right-size phases**: Not too granular, not too broad
- **Dependencies clear**: Later phases build on earlier ones

## For Each Phase:
- Clear, implementable feature description
- Dependencies on previous phases
- Success criteria (testable/verifiable)
- Estimated complexity (simple/medium/complex)
- **Environment variables needed** (specify in .env.example)
- **Recommended MCPs** (if using MCPs, suggest appropriate ones)

## MCP (Model Context Protocol) Integration:
For each phase, consider which MCP profile would enhance AI capabilities:

**Available Profiles**:
- default: Basic services (github, filesystem, memory)
- research: Extended search capabilities (adds omnisearch, context7)
- development: Code analysis tools
- project-specific: Custom profiles if needed

**Examples**:
- Planning phases → 'research' profile
- Implementation phases → 'development' profile
- Simple tasks → 'default' profile

Include in each phase's INITIAL.md which MCP profile is recommended.
View available profiles with: mcp-manager profile

## Environment Variables (.env.example):
Create a comprehensive .env.example file that includes:
- All environment variables for the entire project
- Phase notifications in comments
- Where to obtain each key/value
- Example formats (without real secrets)

Follow the template format shown in: examples/env-example-template.md

## Additional Files:
- future-features/ # Ideas for beyond the roadmap
- documentation/   # Architecture decisions as we go
- MCP_RECOMMENDATIONS.md # (Optional) New MCPs not in the catalog

## MCP_RECOMMENDATIONS.md Format:
If you recommend MCPs that aren't in the standard catalog, create this file:

```markdown
# MCP Recommendations

## mcp-name
Purpose: What this MCP does and why it's needed
API Key: Where to get the API key (URL or "No API key needed")
Setup: npm package name or installation instructions

## another-mcp
Purpose: Description
API Key: https://example.com/api-keys
Setup: npx -y @org/mcp-package
```

Please create all these files with appropriate content.

## Available Example Patterns:
You have access to example patterns in the examples/ directory:
- agent_architecture_pattern.py - Shows agent/tools/prompts structure
- health_check_pattern.py - Comprehensive health monitoring
- logging_pattern.py - Structured logging best practices
- phase_management_pattern.py - Phase-aware feature flags
- project_structure.py - Module organization patterns

Use these patterns to guide your implementation.

## Confidence Rating
After your analysis and roadmap creation, provide a confidence rating:

**Confidence: [0-10]/10**

Explain your confidence level based on:
- Clarity of requirements
- Complexity of the project
- Identified risks
- For refactor/retry: Quality of existing code analysis

The user will review your roadmap and confidence before proceeding.
EOF
}

# Check for MCP recommendations
check_mcp_recommendations() {
    # Look for MCP_RECOMMENDATIONS.md if it exists
    if [[ -f "MCP_RECOMMENDATIONS.md" ]]; then
        print_header "📡 MCP Recommendations"
        
        echo -e "${YELLOW}The following MCP servers were recommended for this project:${NC}"
        echo ""
        
        # Parse recommendations (Claude should create this file)
        while IFS= read -r line; do
            if [[ "$line" =~ ^##[[:space:]](.+) ]]; then
                mcp_name="${BASH_REMATCH[1]}"
                
                # Check if MCP exists in catalog
                SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
                MCP_CATALOG="$(dirname "$SCRIPT_DIR")/mcp-catalog"
                
                if [[ -f "$MCP_CATALOG/$mcp_name.json" ]]; then
                    echo -e "${GREEN}✅ $mcp_name${NC} - Already in catalog"
                else
                    echo -e "${RED}❌ $mcp_name${NC} - NEW MCP NEEDED"
                    
                    # Read details from next lines
                    read -r purpose_line
                    read -r api_line
                    read -r setup_line
                    
                    echo "   Purpose: $purpose_line"
                    echo "   API Key: $api_line"
                    echo "   Setup: $setup_line"
                    echo ""
                    
                    read -p "   Add this MCP to the catalog? (y/n) [y]: " add_mcp
                    add_mcp=${add_mcp:-y}
                    
                    if [[ "$add_mcp" == "y" ]]; then
                        # Create basic MCP entry
                        cat > "$MCP_CATALOG/$mcp_name.json" << EOF
{
  "name": "$mcp_name",
  "description": "$purpose_line",
  "use_cases": ["As recommended by AI for this project"],
  "recommended_phases": ["all"],
  "env_vars": {},
  "setup_instructions": "$setup_line",
  "documentation": "$api_line",
  "mcp_config": {
    "command": "npx",
    "args": ["-y", "@modelcontextprotocol/server-$mcp_name"],
    "env": {}
  }
}
EOF
                        print_success "Added $mcp_name to catalog (needs configuration)"
                        echo "   Edit $MCP_CATALOG/$mcp_name.json to complete setup"
                    fi
                fi
            fi
        done < "MCP_RECOMMENDATIONS.md"
        
        echo ""
        echo -e "${GREEN}MCP Setup Summary:${NC}"
        echo "1. Review .env.example for required API keys"
        echo "2. Copy .env.mcp.example to .env.mcp and add your API keys"
        echo "3. Configure with: ./bin/generate-mcp-config"
        echo ""
    fi
}

# Check for required environment variables
check_environment() {
    if [[ -f ".env.example" ]] && [[ ! -f ".env" ]]; then
        # Auto-create .env from .env.example
        cp .env.example .env
        print_success "Created .env file from template"
    fi
    
    if [[ -f ".env" ]]; then
        # Extract current phase requirements from .env comments
        current_phase=${CURRENT_PHASE:-1}
        
        # Check if any variables are still using placeholder values
        missing_vars=()
        phase_vars=()
        in_current_phase=false
        
        while IFS= read -r line; do
            # Check if we're in the current phase section
            if [[ "$line" =~ ^#.*PHASE[[:space:]]$current_phase: ]]; then
                in_current_phase=true
            elif [[ "$line" =~ ^#.*PHASE[[:space:]][0-9]+: ]]; then
                in_current_phase=false
            fi
            
            # If it's a variable line
            if [[ "$line" =~ ^[A-Z_]+= ]]; then
                var_name=$(echo "$line" | cut -d'=' -f1)
                var_value=$(echo "$line" | cut -d'=' -f2-)
                
                # Track if it's for current phase
                if [[ "$in_current_phase" == true ]]; then
                    phase_vars+=("$var_name")
                fi
                
                # Check if it needs configuration
                if [[ "$var_value" =~ your.*here|^\.\.\.$ ]]; then
                    missing_vars+=("$var_name")
                fi
            fi
        done < .env
        
        # Show phase-specific requirements
        if [[ ${#phase_vars[@]} -gt 0 ]]; then
            echo -e "\n${BLUE}Phase $current_phase Environment Variables:${NC}"
            for var in "${phase_vars[@]}"; do
                if [[ " ${missing_vars[@]} " =~ " ${var} " ]]; then
                    echo -e "  ${RED}❌ $var - Not configured${NC}"
                else
                    echo -e "  ${GREEN}✅ $var - Configured${NC}"
                fi
            done
        fi
        
        # Warn about any missing values
        if [[ ${#missing_vars[@]} -gt 0 ]]; then
            echo -e "\n${YELLOW}Some environment variables need configuration:${NC}"
            echo -e "${YELLOW}Edit .env to add your actual values${NC}"
        fi
    fi
    
    # Check if Python venv needs activation
    if [[ -d "venv" ]] && [[ -z "$VIRTUAL_ENV" ]]; then
        print_warning "Virtual environment not activated!"
        echo -e "${YELLOW}Please activate it with: source venv/bin/activate${NC}"
        read -p "Activate it now? (y/n) [y]: " activate_venv
        activate_venv=${activate_venv:-y}
        
        if [[ "$activate_venv" == "y" ]]; then
            source venv/bin/activate
            print_success "Virtual environment activated"
        fi
    fi
}

# Execute phase with auto-progression
execute_phase() {
    local phase_num=$1
    local phase_dir="phases/phase-$phase_num"
    
    if [[ ! -d "$phase_dir" ]]; then
        print_error "Phase $phase_num directory not found"
        return 1
    fi
    
    print_phase "$phase_num - $(head -n 1 $phase_dir/INITIAL.md | sed 's/# //')"
    
    # Check environment before starting
    check_environment
    
    # Show phase description
    echo -e "${BLUE}Phase Description:${NC}"
    cat "$phase_dir/INITIAL.md"
    echo ""
    
    # Auto-commit before starting
    auto_commit "$phase_num" "Starting phase"
    
    # Generate PRP
    print_header "Generating Implementation Plan..."
    echo -e "${YELLOW}Copy this to Claude Code:${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo "/generate-prp $phase_dir/INITIAL.md"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    
    save_session_state "$phase_num" "generate-prp" "waiting"
    
    read -p "Press Enter when PRP is generated..."
    auto_commit "$phase_num" "PRP generated"
    
    # Find the generated PRP file
    prp_file=""
    if [[ -d "PRPs" ]]; then
        # Find most recent .md file in PRPs directory
        prp_file=$(find PRPs -name "*.md" -type f -exec stat -f "%m %N" {} \; 2>/dev/null | sort -nr | head -1 | cut -d' ' -f2-)
        
        # If nothing found with BSD stat, try GNU stat
        if [[ -z "$prp_file" ]]; then
            prp_file=$(find PRPs -name "*.md" -type f -exec stat -c "%Y %n" {} \; 2>/dev/null | sort -nr | head -1 | cut -d' ' -f2-)
        fi
    fi
    
    # Fallback to wildcard pattern if we couldn't detect
    if [[ -z "$prp_file" ]]; then
        prp_file="PRPs/phase-$phase_num-*.md"
    fi
    
    # Additional commit for PRP review
    echo -e "\n${BLUE}PRP Review:${NC}"
    echo "Take a moment to review the generated PRP"
    if [[ "$prp_file" != *"*"* ]] && [[ -f "$prp_file" ]]; then
        echo -e "${CYAN}PRP created at: $prp_file${NC}"
    fi
    read -p "Any changes needed to the PRP? (y/n) [n]: " prp_changes
    prp_changes=${prp_changes:-n}
    
    if [[ "$prp_changes" == "y" ]]; then
        echo "Make your changes to the PRP, then press Enter"
        read -p "Press Enter when PRP changes are complete..."
        auto_commit "$phase_num" "PRP refined"
    fi
    
    # Execute PRP
    print_header "Executing Implementation..."
    echo -e "${YELLOW}Copy this to Claude Code:${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo "/execute-prp $prp_file"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    
    save_session_state "$phase_num" "execute-prp" "in-progress"
    
    echo -e "\n${GREEN}While Claude Code is working:${NC}"
    echo "- Watch the implementation progress"
    echo "- Let it complete all validations"
    echo "- Review the changes when done"
    
    read -p "Press Enter when implementation is complete..."
    auto_commit "$phase_num" "Implementation complete"
    
    # Test phase (if applicable)
    if [[ -d "tests" ]] || [[ -f "pytest.ini" ]] || [[ -f "package.json" ]]; then
        print_header "Testing Phase..."
        echo -e "${YELLOW}Run your test suite:${NC}"
        echo "  Python: pytest"
        echo "  JavaScript: npm test"
        echo "  Go: go test ./..."
        echo ""
        
        read -p "Have you run the tests? (y/n) [y]: " ran_tests
        ran_tests=${ran_tests:-y}
        
        if [[ "$ran_tests" == "y" ]]; then
            read -p "Did all tests pass? (y/n) [y]: " tests_passed
            tests_passed=${tests_passed:-y}
            
            if [[ "$tests_passed" == "y" ]]; then
                auto_commit "$phase_num" "Tests passing"
            else
                print_warning "Tests are failing"
                echo "Options:"
                echo "1) Fix tests now"
                echo "2) Continue with failing tests"
                read -p "Choose option [1]: " test_option
                test_option=${test_option:-1}
                
                if [[ "$test_option" == "1" ]]; then
                    echo "Fix the tests, then press Enter"
                    read -p "Press Enter when tests are fixed..."
                    auto_commit "$phase_num" "Tests fixed"
                else
                    auto_commit "$phase_num" "Tests failing (known issue)"
                fi
            fi
        fi
    fi
    
    # Check success criteria
    print_header "Validating Phase Completion..."
    echo -e "${BLUE}Success Criteria:${NC}"
    cat "$phase_dir/SUCCESS_CRITERIA.md"
    echo ""
    
    read -p "Does this phase meet all success criteria? (y/n) [y]: " success
    success=${success:-y}
    
    if [[ "$success" != "y" ]]; then
        print_warning "Phase needs revision"
        save_session_state "$phase_num" "needs-revision" "failed"
        
        echo -e "\n${YELLOW}Options:${NC}"
        echo "1) Rollback to last commit and retry"
        echo "2) Continue anyway (fix later)"
        echo "3) Exit to fix manually"
        
        read -p "Choose option [1]: " option
        option=${option:-1}
        
        case $option in
            1)
                git reset --hard HEAD~1
                print_success "Rolled back to previous commit"
                return 1
                ;;
            2)
                print_warning "Continuing with issues noted"
                auto_commit "$phase_num" "Phase complete with issues"
                ;;
            3)
                save_session_state "$phase_num" "manual-fix" "paused"
                exit 0
                ;;
        esac
    else
        auto_commit "$phase_num" "Phase complete and validated"
        save_session_state "$phase_num" "complete" "success"
    fi
    
    return 0
}

# Main continuous workflow
continuous_workflow() {
    print_header "🚀 Context Engineer - Auto-Pilot Mode"
    
    # Check if resuming
    if load_session_state; then
        print_warning "Found existing session"
        echo "Project: $PROJECT_PATH"
        echo "Phase: $CURRENT_PHASE"
        echo "Status: $STATUS"
        echo ""
        
        read -p "Resume from phase $CURRENT_PHASE? (y/n) [y]: " resume
        resume=${resume:-y}
        
        if [[ "$resume" == "y" ]]; then
            cd "$PROJECT_PATH"
            start_phase=$CURRENT_PHASE
        else
            # Starting fresh, need to create new project
            create_new_project
            start_phase=1
        fi
    else
        # No session, check if we're in a Context Engineering project
        if [[ -f "CLAUDE.md" && -d ".claude" ]]; then
            # Additional safety check - don't run in Desktop or home directory
            current_dir=$(pwd)
            if [[ "$current_dir" == "$HOME/Desktop" || "$current_dir" == "$HOME" ]]; then
                print_error "Cannot run auto-pilot mode in Desktop or Home directory!"
                echo "Please either:"
                echo "1. Create a new project (it will ask for a name)"
                echo "2. Navigate to an existing project directory"
                echo ""
                create_new_project
            else
                print_success "Found existing Context Engineering project"
                PROJECT_PATH=$(pwd)
            fi
        else
            # Need to create new project
            create_new_project
            # We're now in the project directory after create_new_project
        fi
        start_phase=1
    fi
    
    # Make sure we're in the project directory
    if [[ -n "$PROJECT_PATH" ]] && [[ "$PROJECT_PATH" != "$(pwd)" ]]; then
        cd "$PROJECT_PATH"
    fi
    
    # NOW we're in the project directory, initialize git if needed
    if [[ ! -d .git ]]; then
        git init
        git add -A
        git commit -m "Initial commit: Context Engineering project" --quiet
        print_success "Git repository initialized"
    fi
    
    # Check for roadmap
    if [[ -f "$ROADMAP_FILE" ]]; then
        print_success "Found existing roadmap"
    else
        print_header "📋 Project Planning Phase"
        
        # Get project name from current directory or ask
        if [[ -n "$project_name" ]]; then
            echo "Project: $project_name"
        else
            project_name=$(basename "$(pwd)")
            echo "Project: $project_name"
        fi
        
        read -p "Main goal (one sentence): " main_goal
        
        print_header "Generate Project Roadmap"
        echo -e "${YELLOW}Copy this prompt to Claude Code:${NC}"
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        generate_roadmap_prompt "$project_name" "$main_goal"
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        
        read -p "Press Enter when roadmap is created..."
        
        # For refactor/retry projects, ask for roadmap approval
        if [[ -f "REFACTOR_CONTEXT.md" ]] || [[ -f "RETRY_CONTEXT.md" ]]; then
            print_header "Review Roadmap"
            echo -e "${YELLOW}Please review the generated roadmap and confidence rating.${NC}"
            echo ""
            echo "The AI should have:"
            echo "1. Analyzed the existing codebase thoroughly"
            echo "2. Created a phase-based improvement plan"
            echo "3. Provided a confidence rating (0-10)"
            echo ""
            read -p "Do you approve this roadmap? (y/n) [y]: " approve_roadmap
            approve_roadmap=${approve_roadmap:-y}
            
            if [[ "$approve_roadmap" != "y" ]]; then
                print_warning "Roadmap not approved. Please provide feedback to Claude and regenerate."
                echo ""
                echo "You can:"
                echo "1. Provide specific feedback about what needs to change"
                echo "2. Ask for a different approach or focus"
                echo "3. Request more analysis of specific areas"
                echo ""
                echo "When ready, run 'cea' again to continue."
                exit 0
            fi
            
            print_success "Roadmap approved!"
        fi
        
        # MCP recommendations handled separately
        # check_mcp_recommendations
        
        # Create .env from .env.example if it was generated
        if [[ -f ".env.example" ]] && [[ ! -f ".env" ]]; then
            cp .env.example .env
            print_success "Created .env from template - ready for configuration"
        fi
        
        auto_commit "0" "Roadmap and phase structure created"
    fi
    
    # Count total phases
    total_phases=$(find phases -name "phase-*" -type d 2>/dev/null | wc -l)
    
    if [[ $total_phases -eq 0 ]]; then
        print_error "No phases found in phases/ directory"
        echo ""
        echo "This usually means the roadmap hasn't been generated yet."
        echo "Please ensure you've copied the roadmap prompt to Claude Code"
        echo "and that it has created the phase structure."
        echo ""
        echo "Run 'cea' again after generating the roadmap."
        exit 1
    fi
    
    print_success "Found $total_phases phases in roadmap"
    
    # Execute phases sequentially
    for ((phase=$start_phase; phase<=$total_phases; phase++)); do
        print_header "Starting Phase $phase of $total_phases"
        
        if execute_phase "$phase"; then
            print_success "Phase $phase completed successfully!"
            
            if [[ $phase -lt $total_phases ]]; then
                echo -e "\n${GREEN}Ready for next phase?${NC}"
                echo "Next: Phase $((phase + 1))"
                read -p "Continue to next phase? (y/n) [y]: " continue_next
                continue_next=${continue_next:-y}
                
                if [[ "$continue_next" != "y" ]]; then
                    save_session_state "$phase" "complete" "paused"
                    print_warning "Paused after phase $phase. Run 'context-auto' to resume."
                    exit 0
                fi
            fi
        else
            print_warning "Phase $phase needs retry"
            ((phase--))  # Retry the same phase
        fi
    done
    
    # Project complete!
    print_header "🎉 All Phases Complete!"
    
    # Final summary
    echo -e "${GREEN}Project Summary:${NC}"
    echo "- Total phases completed: $total_phases"
    echo "- Git commits: $(git rev-list --count HEAD)"
    echo "- Current branch: $(git branch --show-current)"
    
    # Clean up session file
    rm -f "$SESSION_STATE_FILE"
    
    # Show future features
    if [[ -d "future-features" ]]; then
        echo -e "\n${BLUE}Future Features Available:${NC}"
        ls -1 future-features/*.md 2>/dev/null | sed 's/future-features\//- /'
    fi
}

# Help function
show_help() {
    cat << EOF
Context Engineer - Auto-Pilot Mode

Usage: context-auto [command]

Commands:
  (none)      Start or resume continuous workflow
  --reset     Clear session and start fresh
  --status    Show current session status
  --help      Show this help message

Features:
- Automatic phase progression
- Git commits after each step
- Session persistence (resume anytime)
- Rollback on failures
- No manual command copying needed

Workflow:
1. Generate roadmap (first time only)
2. For each phase:
   - Show phase goals
   - Auto-generate implementation commands
   - Wait for completion
   - Validate success
   - Auto-commit changes
3. Continue until all phases done

The tool handles all command generation - you just:
- Copy/paste to Claude Code when prompted
- Review implementations
- Approve phase completions
EOF
}

# Main entry point
case "${1:-}" in
    --help|-h)
        show_help
        ;;
    --reset)
        rm -f "$SESSION_STATE_FILE"
        print_success "Session state cleared"
        ;;
    --status)
        if load_session_state; then
            echo "Current session:"
            echo "  Project: $PROJECT_PATH"
            echo "  Phase: $CURRENT_PHASE"
            echo "  Step: $CURRENT_STEP"
            echo "  Status: $STATUS"
            echo "  Last update: $TIMESTAMP"
        else
            echo "No active session"
        fi
        ;;
    *)
        continuous_workflow
        ;;
esac