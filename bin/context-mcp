#!/bin/bash

# Context Engineer MCP Manager
# Helps manage MCP servers for Context Engineering projects

set -e

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

# Paths
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
MCP_CATALOG="$(dirname "$SCRIPT_DIR")/mcp-catalog"
MCP_CONFIG=".mcp/mcp.json"
ENV_FILE=".env"

# Functions
print_header() {
    echo -e "\n${BLUE}══════════════════════════════════════════════════════════════${NC}"
    echo -e "${GREEN}$1${NC}"
    echo -e "${BLUE}══════════════════════════════════════════════════════════════${NC}\n"
}

print_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

print_error() {
    echo -e "${RED}❌ $1${NC}"
}

# List available MCPs
list_mcps() {
    print_header "Available MCP Servers"
    
    if [[ ! -d "$MCP_CATALOG" ]]; then
        print_error "MCP catalog not found at: $MCP_CATALOG"
        return 1
    fi
    
    for mcp_file in "$MCP_CATALOG"/*.json; do
        if [[ -f "$mcp_file" ]]; then
            name=$(basename "$mcp_file" .json)
            description=$(jq -r '.description' "$mcp_file" 2>/dev/null || echo "No description")
            echo -e "${CYAN}$name${NC}"
            echo -e "  $description"
            echo ""
        fi
    done
}

# Show MCP details
show_mcp() {
    local mcp_name=$1
    local mcp_file="$MCP_CATALOG/$mcp_name.json"
    
    if [[ ! -f "$mcp_file" ]]; then
        print_error "MCP '$mcp_name' not found"
        return 1
    fi
    
    print_header "MCP: $mcp_name"
    
    # Parse JSON and display
    echo -e "${BLUE}Description:${NC}"
    jq -r '.description' "$mcp_file"
    
    echo -e "\n${BLUE}Use Cases:${NC}"
    jq -r '.use_cases[]' "$mcp_file" | while read -r use_case; do
        echo "  • $use_case"
    done
    
    echo -e "\n${BLUE}Recommended Phases:${NC}"
    jq -r '.recommended_phases[]' "$mcp_file" | while read -r phase; do
        echo "  • $phase"
    done
    
    # Check for environment variables
    env_vars=$(jq -r '.env_vars | to_entries[] | "\(.key)=\(.value)"' "$mcp_file" 2>/dev/null)
    if [[ -n "$env_vars" ]]; then
        echo -e "\n${BLUE}Required Environment Variables:${NC}"
        echo "$env_vars" | while IFS='=' read -r key value; do
            echo -e "  ${YELLOW}$key${NC}"
            echo -e "    $value"
        done
    fi
    
    echo -e "\n${BLUE}Setup Instructions:${NC}"
    jq -r '.setup_instructions' "$mcp_file"
}

# Enable MCP for current project
enable_mcp() {
    local mcp_name=$1
    local mcp_file="$MCP_CATALOG/$mcp_name.json"
    
    if [[ ! -f "$mcp_file" ]]; then
        print_error "MCP '$mcp_name' not found"
        return 1
    fi
    
    if [[ ! -f "$MCP_CONFIG" ]]; then
        print_error "No .mcp/mcp.json found. Are you in a Context Engineering project?"
        return 1
    fi
    
    print_header "Enabling $mcp_name"
    
    # Get MCP config
    local config=$(jq -r '.mcp_config' "$mcp_file")
    
    # Create a proper MCP entry
    echo -e "${YELLOW}Add this to your .mcp/mcp.json:${NC}"
    echo -e "${CYAN}----------------------------------------${NC}"
    echo "\"$mcp_name\": $(echo "$config" | jq -c .)"
    echo -e "${CYAN}----------------------------------------${NC}"
    
    # Check for required env vars
    local env_vars=$(jq -r '.env_vars | keys[]' "$mcp_file" 2>/dev/null)
    if [[ -n "$env_vars" ]]; then
        echo -e "\n${YELLOW}Required environment variables:${NC}"
        for var in $env_vars; do
            if grep -q "^$var=" "$ENV_FILE" 2>/dev/null; then
                echo -e "  ${GREEN}✅ $var${NC} - Found in .env"
            else
                echo -e "  ${RED}❌ $var${NC} - Missing from .env"
                description=$(jq -r ".env_vars.\"$var\"" "$mcp_file")
                echo -e "     Add to .env: ${YELLOW}$var=your-key-here${NC}"
                echo -e "     $description"
            fi
        done
    fi
    
    echo -e "\n${GREEN}Next steps:${NC}"
    echo "1. Add the configuration above to .mcp/mcp.json"
    echo "2. Add any missing API keys to .env"
    echo "3. Restart Claude Code"
}

# Check MCP status for project
check_status() {
    print_header "MCP Status for Current Project"
    
    if [[ ! -f "$MCP_CONFIG" ]]; then
        print_error "No .mcp/mcp.json found"
        return 1
    fi
    
    # Parse enabled MCPs
    echo -e "${BLUE}Configured MCPs:${NC}"
    
    # Get all keys that don't start with //
    local mcps=$(jq -r 'keys[] | select(startswith("//") | not)' "$MCP_CONFIG" 2>/dev/null)
    
    if [[ -z "$mcps" ]]; then
        print_warning "No MCPs are currently enabled"
        echo "All MCPs are commented out or config is empty"
    else
        for mcp in $mcps; do
            echo -e "  ${GREEN}✅ $mcp${NC} - Enabled"
            
            # Check if disabled
            local disabled=$(jq -r ".\"$mcp\".disabled // false" "$MCP_CONFIG")
            if [[ "$disabled" == "true" ]]; then
                echo -e "     ${YELLOW}(Currently disabled)${NC}"
            fi
        done
    fi
    
    # Check environment variables
    echo -e "\n${BLUE}Environment Check:${NC}"
    if [[ -f "$ENV_FILE" ]]; then
        # Common MCP env vars
        for var in TAVILY_API_KEY GITHUB_PERSONAL_ACCESS_TOKEN OPENAI_API_KEY; do
            if grep -q "^$var=" "$ENV_FILE"; then
                value=$(grep "^$var=" "$ENV_FILE" | cut -d'=' -f2)
                if [[ "$value" =~ your.*here|^\.\.\.$ ]]; then
                    echo -e "  ${YELLOW}⚠️  $var${NC} - Needs configuration"
                else
                    echo -e "  ${GREEN}✅ $var${NC} - Configured"
                fi
            fi
        done
    else
        print_warning "No .env file found"
    fi
}

# Recommend MCPs for phase
recommend_phase() {
    local phase=$1
    
    print_header "Recommended MCPs for Phase: $phase"
    
    case "$phase" in
        planning|research|1|2)
            echo -e "${BLUE}Planning & Research Phase MCPs:${NC}"
            echo -e "  ${CYAN}context7${NC} - Up-to-date library documentation"
            echo -e "  ${CYAN}omnisearch${NC} - Web search for patterns and solutions"
            echo -e "  ${CYAN}sequential-thinking${NC} - Problem decomposition"
            echo -e "  ${CYAN}memory${NC} - Start building project context"
            ;;
        development|implementation|3|4|5)
            echo -e "${BLUE}Development Phase MCPs:${NC}"
            echo -e "  ${CYAN}context7${NC} - API documentation"
            echo -e "  ${CYAN}memory${NC} - Maintain project context"
            echo -e "  ${CYAN}github${NC} - Version control operations"
            ;;
        integration|deployment|6|7|8)
            echo -e "${BLUE}Integration & Deployment MCPs:${NC}"
            echo -e "  ${CYAN}github${NC} - PR creation and releases"
            echo -e "  ${CYAN}memory${NC} - Accumulated project knowledge"
            echo -e "  ${CYAN}todoist${NC} - Task tracking (optional)"
            ;;
        *)
            echo "Generic recommendations:"
            echo -e "  ${CYAN}memory${NC} - Always useful for context"
            echo -e "  ${CYAN}context7${NC} - For any library documentation"
            echo -e "  ${CYAN}omnisearch${NC} - When you need to research"
            ;;
    esac
    
    echo -e "\n${GREEN}To enable an MCP:${NC}"
    echo "  context-mcp enable <mcp-name>"
}

# Show help
show_help() {
    cat << EOF
Context Engineer MCP Manager

Usage: context-mcp [command] [args]

Commands:
  list                    List all available MCP servers
  show <mcp-name>        Show details about a specific MCP
  enable <mcp-name>      Get config to enable an MCP
  status                 Check MCP status for current project
  recommend <phase>      Get MCP recommendations for a phase
  help                   Show this help message

Examples:
  context-mcp list                    # See all available MCPs
  context-mcp show omnisearch         # Get details about omnisearch
  context-mcp enable context7         # Enable context7 MCP
  context-mcp status                  # Check current project MCPs
  context-mcp recommend planning      # Get planning phase recommendations

MCP Catalog Location: $MCP_CATALOG
EOF
}

# Main command router
case "${1:-help}" in
    list)
        list_mcps
        ;;
    show)
        if [[ -z "$2" ]]; then
            print_error "Usage: context-mcp show <mcp-name>"
            exit 1
        fi
        show_mcp "$2"
        ;;
    enable)
        if [[ -z "$2" ]]; then
            print_error "Usage: context-mcp enable <mcp-name>"
            exit 1
        fi
        enable_mcp "$2"
        ;;
    status|check)
        check_status
        ;;
    recommend)
        if [[ -z "$2" ]]; then
            print_error "Usage: context-mcp recommend <phase>"
            echo "Phases: planning, development, integration (or 1-8)"
            exit 1
        fi
        recommend_phase "$2"
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        print_error "Unknown command: $1"
        show_help
        exit 1
        ;;
esac