#!/bin/bash

# MCP Configuration Sync from Workhorse
# Pulls configs and injects into local projects

# Load configuration from multiple sources
# 1. Default values
WORKHORSE_IP="${WORKHORSE_IP:-localhost}"
WORKHORSE_USER="${WORKHORSE_USER:-$(whoami)}"
MCP_MASTER_DIR="${MCP_MASTER_DIR:-$HOME/mcp-master}"

# 2. Load from config file if it exists
if [[ -f "$HOME/.config/context-engineer/config.env" ]]; then
    source "$HOME/.config/context-engineer/config.env"
fi

# 3. Load from local .env if it exists (project-specific overrides)
if [[ -f ".env" ]]; then
    source ".env"
fi

LOCAL_CONFIG_DIR="$HOME/.config/context-engineer/mcp"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${GREEN}Syncing MCP configurations from workhorse...${NC}"

# Create local config directory if needed
mkdir -p "$LOCAL_CONFIG_DIR/phase-configs"

# Check SSH connectivity
if ! ssh -q -o ConnectTimeout=5 $WORKHORSE_USER@$WORKHORSE_IP exit 2>/dev/null; then
    echo -e "${RED}❌ Cannot connect to workhorse at $WORKHORSE_IP${NC}"
    echo "Make sure:"
    echo "1. Workhorse is powered on"
    echo "2. You're on the same network"
    echo "3. SSH key authentication is set up"
    exit 1
fi

# Check if master directory exists on workhorse
if ! ssh $WORKHORSE_USER@$WORKHORSE_IP "test -d $MCP_MASTER_DIR" 2>/dev/null; then
    echo -e "${YELLOW}⚠️  Master MCP directory not found on workhorse${NC}"
    echo "Creating $MCP_MASTER_DIR on workhorse..."
    
    ssh $WORKHORSE_USER@$WORKHORSE_IP "mkdir -p $MCP_MASTER_DIR/phase-configs"
    
    echo -e "${YELLOW}Please set up master configurations first:${NC}"
    echo "1. SSH to your server: ssh $WORKHORSE_USER@$WORKHORSE_IP"
    echo "2. Create: $MCP_MASTER_DIR/mcp-config-master.json"
    echo "3. Create: $MCP_MASTER_DIR/api-keys.env"
    echo "4. See docs/SETUP_EXAMPLES.md for configuration details"
    exit 1
fi

# Sync configurations (excluding sensitive files)
echo -e "${BLUE}Syncing phase configurations...${NC}"
rsync -av --exclude='*.env' --exclude='*-master.json' \
    $WORKHORSE_USER@$WORKHORSE_IP:$MCP_MASTER_DIR/ \
    $LOCAL_CONFIG_DIR/

# Pull master config but strip API keys
echo -e "${YELLOW}Processing master configuration...${NC}"
ssh $WORKHORSE_USER@$WORKHORSE_IP "cat $MCP_MASTER_DIR/mcp-config-master.json" > /tmp/mcp-config-master.json

# Create template version without keys
if command -v jq &> /dev/null; then
    jq 'walk(if type == "object" and has("env") then 
        .env |= with_entries(.value = "${" + .key + "}") 
        else . end)' /tmp/mcp-config-master.json > $LOCAL_CONFIG_DIR/mcp-config.json
else
    echo -e "${RED}❌ jq is required but not installed${NC}"
    echo "Install with: brew install jq"
    rm /tmp/mcp-config-master.json
    exit 1
fi

rm /tmp/mcp-config-master.json

# Copy to project if we're in one
if [[ -f "CLAUDE.md" && -d ".mcp" ]]; then
    echo -e "${BLUE}Updating project MCP configuration...${NC}"
    cp $LOCAL_CONFIG_DIR/mcp-config.json .mcp/
    
    # Copy phase configs if they don't exist
    if [[ ! -d ".mcp/phase-configs" ]]; then
        cp -r $LOCAL_CONFIG_DIR/phase-configs .mcp/
        echo -e "${GREEN}✅ Copied phase configurations to project${NC}"
    fi
fi

echo -e "${GREEN}✅ Sync complete!${NC}"
echo ""
echo "Next steps:"
echo "1. Use 'mcp-inject' to inject API keys when needed"
echo "2. Use 'mcp-phase activate <phase>' to enable MCPs"
echo "3. Restart Claude Desktop to load new configurations"