# ================================================
# MCP Services Configuration for Claude Code
# ================================================
# This file contains MCP-specific environment variables
# Copy to .env.mcp and fill in your API keys
#
# To use with Claude Code:
# 1. Copy this file: cp .env.mcp.example .env.mcp
# 2. Fill in your API keys
# 3. Run: ./setup.sh to configure MCPs
# 4. Context Engineer will handle MCP integration automatically
# ================================================

# -------------------------------
# RECOMMENDED MCP SERVICES
# -------------------------------

# --- GitHub MCP ---
# Essential for repository operations
# Get token: https://github.com/settings/tokens/new
# Required scopes: repo, read:org, read:user
GITHUB_TOKEN=

# --- Context7 (Upstash Redis) ---
# Maintains context across sessions
# Free tier: 10,000 commands/day
# Sign up: https://console.upstash.com/
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# --- OmniSearch ---
# Add as many search providers as you want
# At least one is recommended (Brave is free)

# Brave Search (FREE: 2,000/month)
# https://brave.com/search/api/
BRAVE_API_KEY=

# Kagi Search (PAID: Premium results)
# https://kagi.com/settings?p=api
KAGI_API_KEY=

# Perplexity (AI search)
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Tavily (Developer search)
# https://app.tavily.com/
TAVILY_API_KEY=

# Jina Reader (Content extraction)
# https://jina.ai/reader/
JINA_API_KEY=

# Firecrawl (Web scraping)
# https://firecrawl.io/
FIRECRAWL_API_KEY=

# -------------------------------
# OPTIONAL MCP SERVICES
# -------------------------------

# Filesystem MCP
# No API key needed - provides file access

# Memory MCP  
# No API key needed - provides persistent memory

# Sequential Thinking MCP
# No API key needed - helps with complex reasoning

# -------------------------------
# QUICK START
# -------------------------------
# Minimum recommended setup:
# 1. GITHUB_TOKEN (required for most coding tasks)
# 2. BRAVE_API_KEY (free web search)
# 3. UPSTASH_REDIS_* (optional but very useful)
#
# With just these three, you'll have a powerful setup!